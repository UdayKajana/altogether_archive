import os
import dspy
from dspy.teleprompt import BootstrapFewShot

# 2. Set up the Language Model (using OpenAI as an example)
# The dspy.OpenAI class automatically picks up OPENAI_API_KEY from environment variables.
llm = dspy.OpenAI(model='gpt-3.5-turbo', max_tokens=250)
dspy.settings.configure(lm=llm)

print("DSPy installed and language model configured.")

# 3. Define a Chain-of-Thought Signature
class CoT(dspy.Signature):
    """Reason step-by-step to answer the question."""
    question = dspy.InputField()
    answer = dspy.OutputField(desc="answer the question")

# 4. Implement a DSPy Module using Chain-of-Thought
class CoTModule(dspy.Module):
    def __init__(self):
        super().__init__()
        self.prog = dspy.ChainOfThought(CoT)

    def forward(self, question):
        return self.prog(question=question)

# 5. Demonstrate with an example
question = "What is the capital of France?"
cot_predictor = CoTModule()

print(f"\nQuestion: {question}")

# Predict and print the reasoning steps and final answer
response = cot_predictor(question=question)

print("\nDSPy Output:")
print(f"Reasoning: {response.prog.completion.rationale}")
print(f"Answer: {response.answer}")


